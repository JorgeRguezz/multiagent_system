# Copy this file to `.env` at the repo root, then:
#   set -a
#   source .env
#   set +a

# Absolute path to the repository root. By default most modules derive this
# from their own file location, but setting it explicitly makes shell tooling
# and queue runners deterministic on new machines.
export KNOWLEDGE_PROJECT_ROOT="/absolute/path/to/project"

# Optional Hugging Face cache root. Set this if you want model downloads to
# live outside the repo checkout.
export HF_HOME="${KNOWLEDGE_PROJECT_ROOT}/.hf-cache"

# Optional explicit interpreter overrides for MCP subprocesses.
export VENV_SMOLVLM_PYTHON="${KNOWLEDGE_PROJECT_ROOT}/venv_smolvlm/bin/python3"
export VENV_VLM_ASR_PYTHON="${KNOWLEDGE_PROJECT_ROOT}/venv_internVL/bin/python3"

# Optional extraction path overrides.
export KNOWLEDGE_EXTRACTION_WORKING_DIR="${KNOWLEDGE_PROJECT_ROOT}/knowledge_extraction/cache"
export KNOWLEDGE_EXTRACTION_DB_PATH="${KNOWLEDGE_PROJECT_ROOT}/knowledge_extraction/image_matching/lol_champions_square_224.nvdb"
export KNOWLEDGE_EXTRACTION_CHAMPION_ASSETS_ROOT="${KNOWLEDGE_PROJECT_ROOT}/knowledge_extraction/image_matching/assets/champions"

# Optional default input video for single-run extraction.
# Queue mode still reads from downloads/queue.
export KNOWLEDGE_EXTRACTION_VIDEO_PATH="${KNOWLEDGE_PROJECT_ROOT}/downloads/The_COMPLETE_SMOLDER_STARTER_GUIDE_-_League_of_Legends.mp4"

# Optional whisper cache override used by download_models.sh.
# export WHISPER_CACHE_DIR="${KNOWLEDGE_PROJECT_ROOT}/.whisper-cache"
